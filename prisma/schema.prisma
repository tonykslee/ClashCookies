generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlayerActivity {
  guildId String
  tag     String
  name    String
  clanTag String

  lastDonationAt DateTime?
  lastCapitalAt  DateTime?
  lastTrophyAt   DateTime?
  lastWarAt      DateTime?
  lastBuilderAt  DateTime?

  lastTrophies        Int?
  lastWarStars        Int?
  lastBuilderTrophies Int?

  lastSeenAt DateTime
  updatedAt  DateTime @updatedAt

  @@id([guildId, tag])
  @@index([guildId, clanTag])
}

model TrackedClan {
  id              Int       @id @default(autoincrement())
  tag             String    @unique
  name            String?
  loseStyle       LoseStyle @default(TRIPLE_TOP_30)
  mailChannelId   String?
  logChannelId    String?
  clanRoleId      String?
  clanBadge       String?
  shortName       String?
  mailConfig      Json?
  notifyChannelId String?
  notifyRole      String?
  notifyEnabled   Boolean   @default(false)
  createdAt       DateTime  @default(now())
}

model BotSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

model PlayerLink {
  playerTag     String   @id
  discordUserId String
  discordUsername String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum KickListSource {
  AUTO_INACTIVE
  MANUAL
}

enum RecruitmentPlatform {
  discord
  reddit
  band
}

enum WarMatchType {
  FWA
  BL
  MM
  SKIP
}

enum WarPlanScope {
  CUSTOM
  DEFAULT
}

enum WarMailLifecycleStatus {
  NOT_POSTED
  POSTED
  DELETED
}

enum LoseStyle {
  TRADITIONAL
  TRIPLE_TOP_30
}

enum FwaLayoutType {
  RISINGDAWN
  BASIC
  ICE
}


enum TrackedMessageFeatureType {
  FWA_BASE_SWAP
  SYNC_TIME_POST
}

enum TrackedMessageStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  REPLACED
  DELETED
}



model TrackedMessage {
  id          String                    @id @default(cuid())
  guildId     String
  channelId   String
  messageId   String                    @unique
  featureType TrackedMessageFeatureType
  status      TrackedMessageStatus      @default(ACTIVE)
  referenceId String?
  clanTag     String?
  expiresAt   DateTime?
  remindAt    DateTime?
  metadata    Json?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  claims      TrackedMessageClaim[]

  @@index([featureType])
  @@index([status])
  @@index([expiresAt])
  @@index([remindAt])
  @@index([featureType, status])
  @@index([guildId, featureType, status])
  @@index([clanTag, featureType, status])
}

model TrackedMessageClaim {
  id               String         @id @default(cuid())
  trackedMessageId String
  userId           String
  clanTag          String
  createdAt        DateTime       @default(now())
  trackedMessage   TrackedMessage @relation(fields: [trackedMessageId], references: [id], onDelete: Cascade)

  @@unique([trackedMessageId, userId, clanTag])
  @@index([trackedMessageId])
  @@index([userId])
  @@index([clanTag])
}

model KickListEntry {
  id            Int            @id @default(autoincrement())
  guildId       String
  playerTag     String
  playerName    String?
  clanTag       String?
  clanName      String?
  reason        String
  source        KickListSource
  daysThreshold Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([guildId, playerTag, source])
  @@index([guildId, playerTag])
  @@index([guildId, source])
}

model RecruitmentTemplate {
  id         Int                 @id @default(autoincrement())
  guildId    String
  clanTag    String
  platform   RecruitmentPlatform
  subject    String?
  requiredTH String
  focus      String
  body       String
  imageUrls  String[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([guildId, clanTag, platform])
  @@index([guildId, clanTag])
}

model RecruitmentCooldown {
  id        Int                 @id @default(autoincrement())
  guildId   String
  userId    String
  clanTag   String
  platform  RecruitmentPlatform
  startedAt DateTime
  expiresAt DateTime
  reminded  Boolean             @default(false)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([guildId, userId, clanTag, platform])
  @@index([guildId, userId, expiresAt])
  @@index([expiresAt, reminded])
  @@index([expiresAt])
  @@index([guildId, expiresAt, reminded])
}

model WeightInputDeferment {
  id                    String   @id @default(cuid())
  guildId               String
  scopeKey              String
  clanTag               String?
  playerTag             String
  deferredWeight        Int
  status                String   @default("open")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  resolvedAt            DateTime?
  clearedAt             DateTime?
  reminded48At          DateTime?
  escalated5dAt         DateTime?
  summarized7dAt        DateTime?
  processingLockToken   String?
  processingLockExpiresAt DateTime?

  @@unique([scopeKey, playerTag])
  @@index([guildId, status, createdAt])
  @@index([scopeKey, status, createdAt])
  @@index([status, reminded48At, escalated5dAt, summarized7dAt, createdAt])
}

model WarAttacks {
  warId            Int
  clanTag          String
  clanName         String?
  opponentClanTag  String?
  opponentClanName String?
  warStartTime     DateTime
  warEndTime       DateTime?
  warState         String?
  playerTag        String
  playerName       String?
  playerPosition   Int?
  attacksUsed      Int       @default(0)
  attackOrder      Int
  attackNumber     Int
  defenderTag      String?
  defenderName     String?
  defenderPosition Int?
  stars            Int
  trueStars        Int
  destruction      Float
  attackSeenAt     DateTime
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())

  @@id([warId, playerTag, attackNumber])
  @@unique([clanTag, warStartTime, playerTag, attackOrder])
  @@index([clanTag, warStartTime])
  @@index([playerTag, warStartTime])
  @@index([warId])
}

model CurrentWar {
  guildId           String
  clanTag           String
  warId             Int?
  syncNum    Int?
  channelId         String
  notify            Boolean       @default(true)
  pingRole          Boolean       @default(true)
  inferredMatchType Boolean       @default(true)
  notifyRole        String?
  fwaPoints         Int?
  opponentFwaPoints Int?
  outcome           String?
  matchType         WarMatchType?
  warStartFwaPoints Int?
  warEndFwaPoints   Int?
  clanStars     Int?
  opponentStars Int?
  state         String?
  prepStartTime     DateTime?
  startTime         DateTime?
  endTime           DateTime?
  opponentTag   String?
  opponentName  String?
  clanName          String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@id([clanTag, guildId])
  @@index([clanTag])
  @@index([guildId, notify])
  @@index([warId])
  @@index([startTime, clanTag, opponentTag])
}

model ClanNotifyConfig {
  clanTag     String
  guildId     String
  channelId   String
  roleId      String?
  pingEnabled Boolean @default(true)
  embedEnabled Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([guildId, clanTag])
  @@index([guildId])
}

model ClanWarHistory {
  warId               Int           @id @default(autoincrement())
  syncNumber          Int?
  matchType           WarMatchType?
  clanStars           Int?
  clanDestruction     Float?
  opponentStars       Int?
  opponentDestruction Float?
  pointsAfterWar      Int?
  expectedOutcome     String?
  actualOutcome       String?
  prepStartTime       DateTime?
  warStartTime        DateTime
  warEndTime          DateTime?
  clanName            String?
  clanTag             String
  opponentName        String?
  opponentTag         String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  @@unique([warStartTime, clanTag, opponentTag])
  @@index([clanTag, warEndTime])
}

model WarLookup {
  warId       String   @id
  clanTag     String
  opponentTag String?
  startTime   DateTime
  endTime     DateTime?
  result      String?
  payload     Json
  createdAt   DateTime @default(now())

  @@index([clanTag, startTime])
}

model WarEvent {
  warId     Int
  clanTag   String
  eventType String
  createdAt DateTime @default(now())
  payload   Json

  @@id([warId, clanTag, eventType])
  @@index([clanTag, createdAt(sort: Desc)])
}

model ClanPostedMessage {
  id         String   @id @default(cuid())
  guildId    String
  clanTag    String
  type       String
  event      String?
  channelId  String
  messageId  String
  messageUrl String
  warId      String?
  syncNum    Int?
  configHash String?
  createdAt  DateTime @default(now())

  @@index([guildId, clanTag])
  @@index([clanTag, warId])
  @@unique([guildId, clanTag, warId, type, event])
}

model WarMailLifecycle {
  guildId   String
  clanTag   String
  warId     Int
  status    WarMailLifecycleStatus @default(NOT_POSTED)
  messageId String?
  channelId String?
  postedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@id([guildId, clanTag, warId])
  @@index([guildId, clanTag, status])
  @@index([clanTag, warId])
}

model ClanPointsSync {
  id             String   @id @default(cuid())
  guildId        String
  clanTag        String
  warId          String?
  warStartTime   DateTime
  syncNum        Int
  opponentTag    String
  clanPoints     Int
  opponentPoints Int
  outcome        String?
  isFwa          Boolean
  syncFetchedAt  DateTime @default(now())
  lastSuccessfulPointsApiFetchAt DateTime?
  lastFetchReason                String?
  confirmedByClanMail            Boolean  @default(false)
  needsValidation                Boolean  @default(true)
  lastKnownPoints                Int?
  lastKnownMatchType             String?
  lastKnownOutcome               String?
  lastKnownSyncNumber            Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([guildId, clanTag])
  @@index([clanTag, warStartTime])
  @@index([guildId, clanTag, warId])
  @@index([guildId, clanTag, warStartTime(sort: Desc)])
  @@unique([guildId, clanTag, warStartTime])
}

model ClanWarParticipation {
  id                String   @id @default(cuid())
  guildId           String
  warId             String
  clanTag           String
  opponentTag       String?
  playerTag         String
  playerName        String?
  townHall          Int?
  attacksUsed       Int
  attacksMissed     Int
  starsEarned       Int
  trueStars         Int
  missedBoth        Boolean
  firstAttackAt     DateTime?
  attackDelayMinutes Int?
  attackWindowMissed Boolean?
  matchType         String
  warStartTime      DateTime
  warEndTime        DateTime?
  createdAt         DateTime @default(now())

  @@unique([guildId, warId, playerTag])
  @@index([guildId, clanTag, warStartTime])
  @@index([guildId, playerTag])
  @@index([warId])
  @@index([guildId, clanTag, matchType, missedBoth, warStartTime])
}

model ClanWarPlan {
  id                          String      @id @default(cuid())
  guildId                     String
  clanTag                     String
  scope                       WarPlanScope @default(CUSTOM)
  matchType                   WarMatchType
  outcome                     String
  loseStyle                   String      @default("ANY")
  planText                    String
  nonMirrorTripleMinClanStars Int?
  allBasesOpenHoursLeft       Int?
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt

  @@unique([guildId, scope, clanTag, matchType, outcome, loseStyle])
  @@index([guildId, scope, clanTag, matchType])
}

model FwaLayouts {
  Townhall    Int
  Type        FwaLayoutType
  LayoutLink  String
  ImageUrl    String?
  LastUpdated DateTime      @updatedAt

  @@id([Townhall, Type])
  @@index([Type])
}

model ApiUsage {
  endpoint String   @id
  lastCall DateTime
  callCount Int     @default(0)
}

model TelemetryCommandAggregate {
  id              String   @id @default(cuid())
  bucketStart     DateTime
  guildId         String
  commandName     String
  subcommand      String   @default("")
  status          String
  count           Int      @default(0)
  errorCount      Int      @default(0)
  timeoutCount    Int      @default(0)
  totalDurationMs BigInt   @default(0)
  maxDurationMs   Int      @default(0)
  minDurationMs   Int?
  latencyLt250    Int      @default(0)
  latencyLt1000   Int      @default(0)
  latencyLt3000   Int      @default(0)
  latencyLt10000  Int      @default(0)
  latencyGte10000 Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([bucketStart, guildId, commandName, subcommand, status])
  @@index([guildId, bucketStart])
  @@index([commandName, bucketStart])
}

model TelemetryUserCommandAggregate {
  id              String   @id @default(cuid())
  bucketStart     DateTime
  guildId         String
  userId          String
  commandName     String
  subcommand      String   @default("")
  count           Int      @default(0)
  failureCount    Int      @default(0)
  timeoutCount    Int      @default(0)
  totalDurationMs BigInt   @default(0)
  maxDurationMs   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([bucketStart, guildId, userId, commandName, subcommand])
  @@index([guildId, bucketStart])
  @@index([guildId, userId, bucketStart])
}

model TelemetryApiAggregate {
  id              String   @id @default(cuid())
  bucketStart     DateTime
  guildId         String
  commandName     String   @default("")
  namespace       String
  operation       String
  source          String
  status          String
  errorCategory   String   @default("")
  errorCode       String   @default("")
  count           Int      @default(0)
  errorCount      Int      @default(0)
  timeoutCount    Int      @default(0)
  totalDurationMs BigInt   @default(0)
  maxDurationMs   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([bucketStart, guildId, commandName, namespace, operation, source, status, errorCategory, errorCode])
  @@index([guildId, bucketStart])
  @@index([namespace, operation, bucketStart])
}

model TelemetryStageAggregate {
  id              String   @id @default(cuid())
  bucketStart     DateTime
  guildId         String
  commandName     String
  subcommand      String   @default("")
  stage           String
  status          String
  count           Int      @default(0)
  totalDurationMs BigInt   @default(0)
  maxDurationMs   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([bucketStart, guildId, commandName, subcommand, stage, status])
  @@index([guildId, bucketStart])
  @@index([commandName, stage, bucketStart])
}

model TelemetryReportSchedule {
  id                   String   @id @default(cuid())
  guildId              String   @unique
  channelId            String
  cadenceHours         Int      @default(24)
  timezone             String   @default("UTC")
  enabled              Boolean  @default(true)
  lastPostedWindowStart DateTime?
  lastPostedWindowEnd   DateTime?
  lastPostedAt         DateTime?
  lastMessageId        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([enabled, updatedAt])
}

model TelemetryReportRun {
  id           String   @id @default(cuid())
  guildId      String
  channelId    String
  windowStart  DateTime
  windowEnd    DateTime
  cadenceHours Int
  timezone     String
  status       String
  messageId    String?
  errorCode    String?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  postedAt     DateTime?

  @@unique([guildId, windowStart, windowEnd])
  @@index([guildId, status, createdAt])
  @@index([status, createdAt])
}

