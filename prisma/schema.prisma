generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlayerActivity {
  guildId String
  tag     String
  name    String
  clanTag String
  clanName String?

  lastDonationAt DateTime?
  lastCapitalAt  DateTime?
  lastTrophyAt   DateTime?
  lastWarAt      DateTime?
  lastBuilderAt  DateTime?

  lastTrophies        Int?
  lastWarStars        Int?
  lastBuilderTrophies Int?

  lastSeenAt DateTime
  updatedAt  DateTime @updatedAt

  @@id([guildId, tag])
  @@index([guildId, clanTag])
}

model TrackedClan {
  id              Int       @id @default(autoincrement())
  tag             String    @unique
  name            String?
  loseStyle       LoseStyle @default(TRIPLE_TOP_30)
  mailChannelId   String?
  logChannelId    String?
  clanRoleId      String?
  clanBadge       String?
  shortName       String?
  mailConfig      Json?
  notifyChannelId String?
  notifyRole      String?
  notifyEnabled   Boolean   @default(false)
  fwaPoliceDmEnabled  Boolean   @default(false)
  fwaPoliceLogEnabled Boolean   @default(false)
  createdAt       DateTime  @default(now())
}

model BotSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

model PlayerLink {
  playerTag     String   @id
  discordUserId String?
  discordUsername String?
  playerName    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([discordUserId])
}

model UnlinkedAlertConfig {
  guildId    String   @id
  channelId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model UnlinkedPlayer {
  guildId    String
  playerTag  String
  playerName String
  clanTag    String
  clanName   String
  alertedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([guildId, playerTag])
  @@index([guildId, clanTag])
  @@index([guildId, alertedAt])
}

model TodoPlayerSnapshot {
  playerTag       String   @id
  playerName      String
  clanTag         String?
  clanName        String?
  cwlClanTag      String?
  cwlClanName     String?
  warActive       Boolean  @default(false)
  warAttacksUsed  Int      @default(0)
  warAttacksMax   Int      @default(2)
  warPhase        String?
  warEndsAt       DateTime?
  cwlActive       Boolean  @default(false)
  cwlAttacksUsed  Int      @default(0)
  cwlAttacksMax   Int      @default(1)
  cwlPhase        String?
  cwlEndsAt       DateTime?
  raidActive      Boolean  @default(false)
  raidAttacksUsed Int      @default(0)
  raidAttacksMax  Int      @default(6)
  raidEndsAt      DateTime?
  gamesActive     Boolean  @default(false)
  gamesPoints     Int?
  gamesTarget     Int?
  gamesChampionTotal Int?
  gamesSeasonBaseline Int?
  gamesCycleKey   String?
  gamesEndsAt     DateTime?
  lastUpdatedAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clanTag])
  @@index([cwlClanTag])
  @@index([gamesCycleKey])
  @@index([updatedAt])
}

model TodoUserUsage {
  discordUserId String   @id
  activatedAt   DateTime @default(now())
  lastUsedAt    DateTime @updatedAt
}

enum ReminderType {
  WAR_CWL
  RAIDS
  GAMES
  EVENT
}

enum ReminderTargetClanType {
  FWA
  CWL
}

enum ReminderDispatchStatus {
  SENT
  FAILED
}

enum UserActivityReminderType {
  WAR
  CWL
  RAIDS
  GAMES
}

enum UserActivityReminderMethod {
  DM
  PING_HERE
}

enum UserActivityReminderDeliveryStatus {
  SENT
  FAILED
  SKIPPED
}

model Reminder {
  id              String             @id @default(cuid())
  guildId         String
  type            ReminderType
  channelId       String
  isEnabled       Boolean            @default(false)
  createdByUserId String
  updatedByUserId String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  times           ReminderTimeOffset[]
  targetClans     ReminderTargetClan[]
  fireLogs        ReminderFireLog[]

  @@index([guildId, type])
  @@index([guildId, isEnabled])
  @@index([createdAt])
}

model ReminderTimeOffset {
  id            Int      @id @default(autoincrement())
  reminderId    String
  offsetSeconds Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  reminder      Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@unique([reminderId, offsetSeconds])
  @@index([offsetSeconds])
}

model ReminderTargetClan {
  id         Int                    @id @default(autoincrement())
  reminderId String
  clanTag    String
  clanType   ReminderTargetClanType
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  reminder   Reminder               @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@unique([reminderId, clanTag, clanType])
  @@index([clanTag])
  @@index([clanType, clanTag])
}

model ReminderFireLog {
  id             String               @id @default(cuid())
  reminderId     String
  guildId        String
  clanTag        String
  reminderType   ReminderType
  offsetSeconds  Int
  eventIdentity  String
  dedupeKey      String               @unique
  channelId      String
  dispatchStatus ReminderDispatchStatus @default(SENT)
  messageId      String?
  errorMessage   String?
  dispatchedAt   DateTime             @default(now())
  createdAt      DateTime             @default(now())
  reminder       Reminder             @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([reminderId, dispatchedAt])
  @@index([guildId, dispatchedAt])
  @@index([guildId, clanTag, dispatchedAt])
}

model UserActivityReminderRule {
  id               String                       @id @default(cuid())
  discordUserId    String
  type             UserActivityReminderType
  playerTag        String
  method           UserActivityReminderMethod
  offsetMinutes    Int
  surfaceGuildId   String?
  surfaceChannelId String?
  isActive         Boolean                      @default(true)
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  deliveries       UserActivityReminderDelivery[]

  @@unique([discordUserId, type, playerTag, method, offsetMinutes])
  @@index([discordUserId, isActive])
  @@index([type, playerTag, isActive])
}

model UserActivityReminderDelivery {
  id                String                             @id @default(cuid())
  reminderRuleId    String
  eventInstanceKey  String
  scheduledAt       DateTime
  sentAt            DateTime?
  deliveryStatus    UserActivityReminderDeliveryStatus @default(SENT)
  deliverySurface   String?
  errorMessage      String?
  createdAt         DateTime                           @default(now())
  reminderRule      UserActivityReminderRule           @relation(fields: [reminderRuleId], references: [id], onDelete: Cascade)

  @@unique([reminderRuleId, eventInstanceKey])
  @@index([deliveryStatus, createdAt])
  @@index([reminderRuleId, createdAt])
}

model FwaPoliceHandledViolation {
  id                  String   @id @default(cuid())
  clanTag             String
  warId               Int
  playerTag           String
  violationKey        String
  linkedDiscordUserId String?
  dmSentAt            DateTime?
  logSentAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([clanTag, warId, playerTag, violationKey])
  @@index([clanTag, warId, createdAt])
}

model CwlTrackedClan {
  id        Int      @id @default(autoincrement())
  season    String
  tag       String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([season, tag])
  @@index([season, createdAt])
}

model CwlPlayerClanSeason {
  id         Int      @id @default(autoincrement())
  season     String
  playerTag  String
  cwlClanTag String
  playerName String?
  townHall   Int?
  daysParticipated Int @default(0)
  lastRoundDay Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([season, playerTag])
  @@index([season, cwlClanTag])
  @@index([season, playerTag])
}

model CurrentCwlRound {
  season               String
  clanTag              String
  roundDay             Int
  clanName             String?
  opponentTag          String?
  opponentName         String?
  roundState           String
  leagueGroupState     String?
  teamSize             Int?
  attacksPerMember     Int      @default(1)
  preparationStartTime DateTime?
  startTime            DateTime?
  endTime              DateTime?
  sourceUpdatedAt      DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  members              CwlRoundMemberCurrent[]

  @@id([season, clanTag])
  @@unique([season, clanTag, roundDay])
  @@index([season, roundDay])
  @@index([roundState, updatedAt])
}

model CwlRoundMemberCurrent {
  season           String
  clanTag          String
  playerTag        String
  roundDay         Int
  playerName       String
  mapPosition      Int?
  townHall         Int?
  attacksUsed      Int      @default(0)
  attacksAvailable Int      @default(1)
  stars            Int      @default(0)
  destruction      Float    @default(0)
  subbedIn         Boolean  @default(true)
  subbedOut        Boolean  @default(false)
  sourceRoundState String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  currentRound     CurrentCwlRound @relation(fields: [season, clanTag], references: [season, clanTag], onDelete: Cascade)

  @@id([season, clanTag, playerTag])
  @@index([season, clanTag, roundDay])
  @@index([season, playerTag])
  @@index([season, clanTag, subbedIn])
}

model CurrentCwlPrepSnapshot {
  season               String
  clanTag              String
  roundDay             Int
  clanName             String?
  opponentTag          String?
  opponentName         String?
  roundState           String
  leagueGroupState     String?
  preparationStartTime DateTime?
  startTime            DateTime?
  endTime              DateTime?
  lineupJson           Json
  sourceUpdatedAt      DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@id([season, clanTag])
  @@unique([season, clanTag, roundDay])
  @@index([season, roundDay])
  @@index([roundState, updatedAt])
}

model CwlRoundHistory {
  season               String
  clanTag              String
  roundDay             Int
  clanName             String?
  opponentTag          String?
  opponentName         String?
  roundState           String
  leagueGroupState     String?
  teamSize             Int?
  attacksPerMember     Int      @default(1)
  preparationStartTime DateTime?
  startTime            DateTime?
  endTime              DateTime?
  sourceUpdatedAt      DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  members              CwlRoundMemberHistory[]

  @@id([season, clanTag, roundDay])
  @@index([season, clanTag, endTime])
  @@index([season, roundDay])
}

model CwlRoundMemberHistory {
  season           String
  clanTag          String
  roundDay         Int
  playerTag        String
  playerName       String
  mapPosition      Int?
  townHall         Int?
  attacksUsed      Int      @default(0)
  attacksAvailable Int      @default(1)
  stars            Int      @default(0)
  destruction      Float    @default(0)
  subbedIn         Boolean  @default(true)
  subbedOut        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  round            CwlRoundHistory @relation(fields: [season, clanTag, roundDay], references: [season, clanTag, roundDay], onDelete: Cascade)

  @@id([season, clanTag, roundDay, playerTag])
  @@index([season, clanTag, playerTag])
  @@index([season, playerTag])
}

model CwlRotationPlan {
  id                   String   @id @default(cuid())
  clanTag              String
  season               String
  version              Int
  isActive             Boolean  @default(true)
  rosterSize           Int
  generatedFromRoundDay Int?
  excludedPlayerTags   String[]
  warningSummary       String?
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  days                 CwlRotationPlanDay[]

  @@unique([clanTag, season, version])
  @@index([clanTag, season, isActive])
}

model CwlRotationPlanDay {
  id         Int      @id @default(autoincrement())
  planId     String
  roundDay   Int
  lineupSize Int
  locked     Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  plan       CwlRotationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  members    CwlRotationPlanMember[]

  @@unique([planId, roundDay])
  @@index([roundDay])
}

model CwlRotationPlanMember {
  id             Int      @id @default(autoincrement())
  planDayId      Int
  playerTag      String
  playerName     String
  assignmentOrder Int
  manualOverride Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  planDay        CwlRotationPlanDay @relation(fields: [planDayId], references: [id], onDelete: Cascade)

  @@unique([planDayId, playerTag])
  @@index([playerTag])
}

enum KickListSource {
  AUTO_INACTIVE
  MANUAL
}

enum RecruitmentPlatform {
  discord
  reddit
  band
}

enum WarMatchType {
  FWA
  BL
  MM
  SKIP
}

enum WarPlanScope {
  CUSTOM
  DEFAULT
}

enum WarMailLifecycleStatus {
  NOT_POSTED
  POSTED
  DELETED
}

enum LoseStyle {
  TRADITIONAL
  TRIPLE_TOP_30
}

enum FwaLayoutType {
  RISINGDAWN
  BASIC
  ICE
}

enum FwaFeedType {
  CLANS
  CLAN_MEMBERS
  WAR_MEMBERS
  CLAN_WARS
}

enum FwaFeedScopeType {
  GLOBAL
  TRACKED_CLANS
  CLAN_TAG
}

enum FwaFeedSyncStatus {
  IDLE
  SUCCESS
  FAILURE
  NOOP
  SKIPPED
}

enum FwaTrackedClanWarRosterEffectiveWeightStatus {
  RAW
  FILLED_FROM_LOWER_BLOCK
  UNRESOLVED_TRAILING_ZERO
}


enum TrackedMessageFeatureType {
  FWA_BASE_SWAP
  SYNC_TIME_POST
}

enum TrackedMessageStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  REPLACED
  DELETED
}



model TrackedMessage {
  id          String                    @id @default(cuid())
  guildId     String
  channelId   String
  messageId   String                    @unique
  featureType TrackedMessageFeatureType
  status      TrackedMessageStatus      @default(ACTIVE)
  referenceId String?
  clanTag     String?
  expiresAt   DateTime?
  remindAt    DateTime?
  metadata    Json?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  claims      TrackedMessageClaim[]

  @@index([featureType])
  @@index([status])
  @@index([expiresAt])
  @@index([remindAt])
  @@index([featureType, status])
  @@index([guildId, featureType, status])
  @@index([clanTag, featureType, status])
}

model TrackedMessageClaim {
  id               String         @id @default(cuid())
  trackedMessageId String
  userId           String
  clanTag          String
  createdAt        DateTime       @default(now())
  trackedMessage   TrackedMessage @relation(fields: [trackedMessageId], references: [id], onDelete: Cascade)

  @@unique([trackedMessageId, userId, clanTag])
  @@index([trackedMessageId])
  @@index([userId])
  @@index([clanTag])
}

model KickListEntry {
  id            Int            @id @default(autoincrement())
  guildId       String
  playerTag     String
  playerName    String?
  clanTag       String?
  clanName      String?
  reason        String
  source        KickListSource
  daysThreshold Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([guildId, playerTag, source])
  @@index([guildId, playerTag])
  @@index([guildId, source])
}

model RecruitmentTemplate {
  id         Int                 @id @default(autoincrement())
  guildId    String
  clanTag    String
  platform   RecruitmentPlatform
  subject    String?
  requiredTH String
  focus      String
  body       String
  imageUrls  String[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([guildId, clanTag, platform])
  @@index([guildId, clanTag])
}

model RecruitmentCooldown {
  id        Int                 @id @default(autoincrement())
  guildId   String
  userId    String
  clanTag   String
  platform  RecruitmentPlatform
  startedAt DateTime
  expiresAt DateTime
  reminded  Boolean             @default(false)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([guildId, userId, clanTag, platform])
  @@index([guildId, userId, expiresAt])
  @@index([expiresAt, reminded])
  @@index([expiresAt])
  @@index([guildId, expiresAt, reminded])
}

model RecruitmentReminderRule {
  id               String                    @id @default(cuid())
  guildId          String
  discordUserId    String
  clanTag          String
  platform         String
  timezone         String
  nextReminderAt   DateTime
  isActive         Boolean                   @default(true)
  lastSentAt       DateTime?
  clanNameSnapshot String?
  templateSubject  String?
  templateBody     String
  templateImageUrls String[]
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  deliveries       RecruitmentReminderDelivery[]

  @@unique([guildId, discordUserId, clanTag, platform])
  @@index([guildId, discordUserId, isActive])
  @@index([guildId, nextReminderAt, isActive])
  @@index([guildId, clanTag, platform])
}

model RecruitmentReminderDelivery {
  id               String                    @id @default(cuid())
  reminderRuleId   String
  scheduledFor     DateTime
  sentAt           DateTime?
  status           String
  errorDetails     String?
  createdAt        DateTime                  @default(now())
  reminderRule     RecruitmentReminderRule   @relation(fields: [reminderRuleId], references: [id], onDelete: Cascade)

  @@unique([reminderRuleId, scheduledFor])
  @@index([status, createdAt])
  @@index([reminderRuleId, createdAt])
}

model WeightInputDeferment {
  id                    String   @id @default(cuid())
  guildId               String
  scopeKey              String
  clanTag               String?
  playerTag             String
  deferredWeight        Int
  status                String   @default("open")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  resolvedAt            DateTime?
  clearedAt             DateTime?
  reminded48At          DateTime?
  escalated5dAt         DateTime?
  summarized7dAt        DateTime?
  processingLockToken   String?
  processingLockExpiresAt DateTime?

  @@unique([scopeKey, playerTag])
  @@index([guildId, status, createdAt])
  @@index([scopeKey, status, createdAt])
  @@index([status, reminded48At, escalated5dAt, summarized7dAt, createdAt])
}

model WarAttacks {
  warId            Int
  clanTag          String
  clanName         String?
  opponentClanTag  String?
  opponentClanName String?
  warStartTime     DateTime
  warEndTime       DateTime?
  warState         String?
  playerTag        String
  playerName       String?
  playerPosition   Int?
  attacksUsed      Int       @default(0)
  attackOrder      Int
  attackNumber     Int
  defenderTag      String?
  defenderName     String?
  defenderPosition Int?
  stars            Int
  trueStars        Int
  destruction      Float
  attackSeenAt     DateTime
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())

  @@id([warId, playerTag, attackNumber])
  @@unique([clanTag, warStartTime, playerTag, attackOrder])
  @@index([clanTag, warStartTime])
  @@index([playerTag, warStartTime])
  @@index([warId])
}

model CurrentWar {
  guildId           String
  clanTag           String
  warId             Int?
  syncNum    Int?
  channelId         String
  notify            Boolean       @default(true)
  pingRole          Boolean       @default(true)
  inferredMatchType Boolean       @default(true)
  notifyRole        String?
  fwaPoints         Int?
  opponentFwaPoints Int?
  outcome           String?
  matchType         WarMatchType?
  warStartFwaPoints Int?
  warEndFwaPoints   Int?
  clanStars     Int?
  opponentStars Int?
  state         String?
  prepStartTime     DateTime?
  startTime         DateTime?
  endTime           DateTime?
  opponentTag   String?
  opponentName  String?
  clanName          String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@id([clanTag, guildId])
  @@index([clanTag])
  @@index([guildId, notify])
  @@index([warId])
  @@index([startTime, clanTag, opponentTag])
}

model ClanNotifyConfig {
  clanTag     String
  guildId     String
  channelId   String
  roleId      String?
  pingEnabled Boolean @default(true)
  embedEnabled Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([guildId, clanTag])
  @@index([guildId])
}

model ClanWarHistory {
  warId               Int           @id @default(autoincrement())
  syncNumber          Int?
  matchType           WarMatchType?
  clanStars           Int?
  clanDestruction     Float?
  opponentStars       Int?
  opponentDestruction Float?
  pointsAfterWar      Int?
  expectedOutcome     String?
  actualOutcome       String?
  prepStartTime       DateTime?
  warStartTime        DateTime
  warEndTime          DateTime?
  clanName            String?
  clanTag             String
  opponentName        String?
  opponentTag         String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  @@unique([warStartTime, clanTag, opponentTag])
  @@index([clanTag, warEndTime])
}

model WarLookup {
  warId       String   @id
  clanTag     String
  opponentTag String?
  startTime   DateTime
  endTime     DateTime?
  result      String?
  payload     Json
  createdAt   DateTime @default(now())

  @@index([clanTag, startTime])
}

model WarEvent {
  warId     Int
  clanTag   String
  eventType String
  createdAt DateTime @default(now())
  payload   Json

  @@id([warId, clanTag, eventType])
  @@index([clanTag, createdAt(sort: Desc)])
}

model ClanPostedMessage {
  id         String   @id @default(cuid())
  guildId    String
  clanTag    String
  type       String
  event      String?
  channelId  String
  messageId  String
  messageUrl String
  warId      String?
  syncNum    Int?
  configHash String?
  createdAt  DateTime @default(now())

  @@index([guildId, clanTag])
  @@index([clanTag, warId])
  @@unique([guildId, clanTag, warId, type, event])
}

model WarMailLifecycle {
  guildId   String
  clanTag   String
  warId     Int
  status    WarMailLifecycleStatus @default(NOT_POSTED)
  messageId String?
  channelId String?
  postedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@id([guildId, clanTag, warId])
  @@index([guildId, clanTag, status])
  @@index([clanTag, warId])
}

model ClanPointsSync {
  id             String   @id @default(cuid())
  guildId        String
  clanTag        String
  warId          String?
  warStartTime   DateTime
  syncNum        Int
  opponentTag    String
  clanPoints     Int
  opponentPoints Int
  outcome        String?
  isFwa          Boolean
  syncFetchedAt  DateTime @default(now())
  lastSuccessfulPointsApiFetchAt DateTime?
  lastFetchReason                String?
  confirmedByClanMail            Boolean  @default(false)
  needsValidation                Boolean  @default(true)
  lastKnownPoints                Int?
  lastKnownMatchType             String?
  lastKnownOutcome               String?
  lastKnownSyncNumber            Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([guildId, clanTag])
  @@index([clanTag, warStartTime])
  @@index([guildId, clanTag, warId])
  @@index([guildId, clanTag, warStartTime(sort: Desc)])
  @@unique([guildId, clanTag, warStartTime])
}

model ClanWarParticipation {
  id                String   @id @default(cuid())
  guildId           String
  warId             String
  clanTag           String
  opponentTag       String?
  playerTag         String
  playerName        String?
  townHall          Int?
  attacksUsed       Int
  attacksMissed     Int
  starsEarned       Int
  trueStars         Int
  missedBoth        Boolean
  firstAttackAt     DateTime?
  attackDelayMinutes Int?
  attackWindowMissed Boolean?
  matchType         String
  warStartTime      DateTime
  warEndTime        DateTime?
  createdAt         DateTime @default(now())

  @@unique([guildId, warId, playerTag])
  @@index([guildId, clanTag, warStartTime])
  @@index([guildId, playerTag])
  @@index([warId])
  @@index([guildId, clanTag, matchType, missedBoth, warStartTime])
}

model ClanWarPlan {
